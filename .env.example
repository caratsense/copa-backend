# Database (Railway provides this automatically when you add PostgreSQL)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Redis (Railway provides this when you add Redis)
REDIS_URL=redis://default:pass@host:6379

# JWT
JWT_SECRET=your-secret-key-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440

# CORS
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# WhatsApp (set WHATSAPP_ENABLED=true when ready)
WHATSAPP_ENABLED=false
WHATSAPP_PHONE_ID=
WHATSAPP_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=cakeoclock2026
WHATSAPP_BUSINESS_PHONE=919554444462
WHATSAPP_TRACKING_BASE_URL=https://your-app.vercel.app/track
WHATSAPP_REVIEW_BASE_URL=https://your-app.vercel.app/menu

# Gemini AI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# SMS OTP — 2factor.in (used for login + forgot-password)
# When false: dev mode, OTP logged to console and "000000" always works.
SMS_ENABLED=false
TWOFACTOR_API_KEY=
# Optional: only if you created a custom AUTOGEN template in the 2factor dashboard
TWOFACTOR_TEMPLATE=
